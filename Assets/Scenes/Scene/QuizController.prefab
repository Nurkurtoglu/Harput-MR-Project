  m_Script: {fileID: 11500000, guid: f8ba035c69a718f4f8d112ebc3e6006d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::QuizManager
  questions:
  - questionText: "Harput'un en bilinen simgelerinden biri olan Harput Kalesi'nin
      yap\u0131m\u0131 s\u0131ras\u0131nda, kurakl\u0131k nedeniyle harc\u0131nda
      su yerine ba\u015Fka bir s\u0131v\u0131 kullan\u0131ld\u0131\u011F\u0131 efsanesi
      g\xFCn\xFCm\xFCze kadar ula\u015Fm\u0131\u015Ft\u0131r. Bu efsaneye dayanarak
      Harput Kalesi halk aras\u0131nda hangi isimle de an\u0131lmaktad\u0131r?"
    answers:
    - "S\xFCt Kalesi"
    - Bulut Kalesi
    - Su Kalesi
    - Beyaz Kale
    correctAnswerIndex: 0
  - questionText: "Harput'ta bulunan ve \u0130talya'daki \xFCnl\xFC Pisa Kulesi'nden
      daha e\u011Fik oldu\u011Fu tescillenen tarihi yap\u0131 hangisidir?"
    answers:
    - "Arap Baba T\xFCrbesi"
    - "Kur\u015Funlu Camii"
    - Meryem Ana Kilisesi
    - Harput Ulu Camii Minaresi
    correctAnswerIndex: 3
  - questionText: "Harput'ta yer alan, jeolojik yap\u0131s\u0131 nedeniyle yaz aylar\u0131nda
      i\xE7i buz gibi serin, k\u0131\u015F aylar\u0131nda ise nispeten s\u0131cak
      olan do\u011Fa harikas\u0131 yerin ad\u0131 nedir?"
    answers:
    - "Damlata\u015F Ma\u011Faras\u0131"
    - "Buzluk Ma\u011Faras\u0131"
    - "Karain Ma\u011Faras\u0131"
    - "\u0130nsuyu Ma\u011Faras\u0131"
    correctAnswerIndex: 1
  - questionText: "Harput'ta yer alan, jeolojik yap\u0131s\u0131 nedeniyle yaz aylar\u0131nda
      i\xE7i buz gibi serin, k\u0131\u015F aylar\u0131nda ise nispeten s\u0131cak
      olan do\u011Fa harikas\u0131 yerin ad\u0131 nedir?"
    answers:
    - "Damlata\u015F Ma\u011Faras\u0131"
    - "Buzluk Ma\u011Faras\u0131"
    - "Karain Ma\u011Faras\u0131"
    - "\u0130nsuyu Ma\u011Faras\u0131"
    correctAnswerIndex: 1
  - questionText: "Harput Kalesi'nin giri\u015Finde \u015Fahlanm\u0131\u015F at \xFCzerinde
      heykeli bulunan ve Harput'u fethederek \xF6nemli bir T\xFCrk yurdu haline getiren
      \xFCnl\xFC komutan kimdir?"
    answers:
    - Alpaarsaln
    - Balak Gazi
    - Battal Gazi
    - Selahaddin Eyyubi
    correctAnswerIndex: 1
